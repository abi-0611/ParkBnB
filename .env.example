# Copy to apps/web/.env.local and apps/mobile/.env — never commit real secrets.

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (Edge Functions / scripts — not in client bundles)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Maps & geocoding (optional — mobile reverse geocode falls back to OSM Nominatim)
NEXT_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_MAPBOX_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
